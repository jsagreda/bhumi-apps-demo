# ─────────────────────────────────────────────────────────────
# Bhumi Yoga · Demo — environment template
# Copy this file to `.env` inside each Vite app (apps/studio-manager,
# apps/erp) and fill it with your OWN Firebase (demo) project values.
# Client-side Firebase keys are safe to expose in the browser bundle,
# but this public repo intentionally ships NO real project config.
# ─────────────────────────────────────────────────────────────

# Firebase web app config (Project settings → General → Your apps → SDK config)
VITE_FIREBASE_API_KEY="your-demo-api-key"
VITE_FIREBASE_AUTH_DOMAIN="your-demo-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="your-demo-project"
VITE_FIREBASE_STORAGE_BUCKET="your-demo-project.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="000000000000"
VITE_FIREBASE_APP_ID="1:000000000000:web:xxxxxxxxxxxx"
VITE_FIREBASE_MEASUREMENT_ID="G-XXXXXXXXXX"

# Optional — AI features (Gemini). Leave blank to disable.
GEMINI_API_KEY=""
