{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": [
    {
      "target": "web",
      "public": "apps/web",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/public-web.html" }]
    },
    {
      "target": "manager",
      "public": "apps/studio-manager/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "erp",
      "public": "apps/erp/dist",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index.html" }]
    },
    {
      "target": "calendar",
      "public": "apps/calendar",
      "ignore": ["firebase.json", "**/.*", "**/node_modules/**"],
      "rewrites": [{ "source": "**", "destination": "/index_calendar.html" }]
    }
  ]
}
